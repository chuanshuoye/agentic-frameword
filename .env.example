# 复制为仓库根目录的 .env 后使用：cp .env.example .env

AGENTIC_SERVER_TOKEN=change-me
AGENTIC_BASE_URL=http://127.0.0.1:8787

# UI 调用需鉴权接口时注入（与 AGENTIC_SERVER_TOKEN 一致，勿提交密钥仓库）
VITE_AGENTIC_SERVER_TOKEN=change-me
# 可选（同一 .env 内配置即可）
# AGENTIC_PORT=8787
# AGENTIC_DB_PATH=
VITE_DOCS_URL=http://localhost:5174/
VITE_SKILL_PROBLEM_TYPES=instruction_clarity,missing_prerequisites,unsafe_command,output_quality,other_custom

# 生产环境优先用环境变量配置 Key；请求体传 apiKey 仅建议本地调试，且不得写入日志/数据库
# Skill 生成（POST /v1/runs/:runId/skill/generate）调用 OpenAI 兼容 Chat Completions
# AGENTIC_SKILL_LLM_BASE_URL=https://api.deepseek.com/v1
# AGENTIC_SKILL_LLM_API_KEY=
# AGENTIC_SKILL_LLM_MODEL=deepseek-chat

# AGENTIC_SKILL_LLM_BASE_URL=https://api.moonshot.cn/v1
# AGENTIC_SKILL_LLM_API_KEY=
# AGENTIC_SKILL_LLM_MODEL=kimi-k2.5

AGENTIC_SKILL_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AGENTIC_SKILL_LLM_API_KEY=
AGENTIC_SKILL_LLM_MODEL=doubao-seed-2-0-pro-260215

# Skill Plan（POST /v1/runs/:runId/skill/plan）可单独配置；不填则回退到 AGENTIC_SKILL_LLM_*
# AGENTIC_SKILL_PLAN_LLM_BASE_URL=
# AGENTIC_SKILL_PLAN_LLM_API_KEY=
# AGENTIC_SKILL_PLAN_LLM_MODEL=

# 会话蒸馏（POST /v1/sessions/distill）可单独配置模型；不填则回退到 AGENTIC_SKILL_LLM_*
AGENTIC_SESSION_DISTILL_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AGENTIC_SESSION_DISTILL_LLM_API_KEY=
AGENTIC_SESSION_DISTILL_LLM_MODEL=doubao-seed-2-0-mini-260215

# 会话同步多源（Cursor / Claude）：POST /v1/sessions/sync 的 body.provider 与下列目录
# AGENTIC_CURSOR_PROJECTS_ROOT=        # 默认 ~/.cursor/projects
# AGENTIC_CURSOR_TRANSCRIPTS_DIR=       # 可选；若设置则启动时同步 cursor_local
# AGENTIC_CLAUDE_PROJECTS_ROOT=        # 可选；未设时优先 AGENTIC_CLAUDE_TRANSCRIPTS_DIR，再 CLAUDE_CONFIG_DIR/projects，再 ~/.claude/projects
# AGENTIC_CLAUDE_TRANSCRIPTS_DIR=       # 可选；覆盖 Claude 根或作为单一 transcripts 目录
# CLAUDE_CONFIG_DIR=                    # 与 Claude CLI 一致时用于推导 projects 路径

